# --- CẤU HÌNH SUPABASE ---
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- CẤU HÌNH WHATSAPP INGESTION ---
WA_AUTH_PATH=./.wwebjs_auth
WA_TRANSCRIPT_LIMIT=20
VIP_MODE=allow_all

# --- CẤU HÌNH WHATSAPP THÔNG BÁO NỘI BỘ ---
WA_INTERNAL_NOTIFY_CHAT_ID=your-group-id@g.us

# --- CẤU HÌNH AI PROVIDER ---
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3-flash-preview

# --- CẤU HÌNH JIRA CLOUD ---
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@dantalabs.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ
JIRA_PARENT_ISSUE_TYPE=Task
JIRA_SUBTASK_ISSUE_TYPE=Sub-task

# --- ACCOUNT IDS CỦA ĐỘI NGŨ OPS TRÊN JIRA ---
JIRA_ASSIGNEE_Phuc_ID=your-phuc-id
JIRA_ASSIGNEE_Tram_ID=your-tram-id
JIRA_ASSIGNEE_Vy_ID=your-vy-id

# --- CẤU HÌNH GMAIL SMTP ---
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
GMAIL_TO=manager@dantalabs.com
GMAIL_FROM=Danta Labs Operations <your-email@gmail.com>

# --- PORT ---
PORT=3000
